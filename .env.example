# --- PostgreSQL ---
POSTGRES_USER=bpm
POSTGRES_PASSWORD=bpm
POSTGRES_DB=bpm_log

# --- Backend ---
# Pour le dev local hors Docker, pointe vers localhost.
# En Docker Compose, l'host est "db" (surchargé par docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://bpm:bpm@localhost:5432/bpm_log

# Mode debug : expose Swagger sur /docs (TOUJOURS false en prod)
DEBUG=true

# CORS : origines autorisées (frontend), séparées par des virgules
# Dev :  CORS_ORIGINS=http://localhost:5173,http://localhost
# Prod : CORS_ORIGINS=https://log.bpmclubsono.com
CORS_ORIGINS=http://localhost:5173,http://localhost

# --- JWT ---
# Génère une clé forte : python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- WebAuthn (Passkey) ---
# rp_id = domaine exact, sans scheme ni port
# Dev :  WEBAUTHN_RP_ID=localhost
# Prod : WEBAUTHN_RP_ID=log.bpmclubsono.com
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=BPM Log
# Dev :  WEBAUTHN_ORIGIN=http://localhost:5173
# Prod : WEBAUTHN_ORIGIN=https://log.bpmclubsono.com
WEBAUTHN_ORIGIN=http://localhost:5173

# --- Web-Push (VAPID) ---
# Génère : python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); ..."
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@bpmclubsono.com

# --- Stockage photos ---
PHOTOS_DIR=/var/bpm/photos

